# ── Infrastructure ───────────────────────────────────────
MONGODB_URI=mongodb://user:password@your-mongo-host:27017/?authSource=admin
REDIS_URL=redis://redis:6379
QDRANT_URL=http://qdrant:6333

# ── AI: DeepInfra (Qwen models) ─────────────────────────
QWEN_8B_ENDPOINT=https://api.deepinfra.com/v1/openai
QWEN_8B_API_KEY=your_deepinfra_api_key
QWEN_32B_API_KEY=your_deepinfra_api_key
QWEN_32B_ENDPOINT=https://api.deepinfra.com/v1/openai
QWEN_235B_API_KEY=your_deepinfra_api_key
QWEN_235B_ENDPOINT=https://api.deepinfra.com/v1/openai

# ── Search API ───────────────────────────────────────────
SERPER_API_KEY=your_serper_api_key

# ── Webshare Proxy ───────────────────────────────────────
WEBSHARE_API_KEY=your_webshare_api_key

# ── Enrichment APIs ──────────────────────────────────────
APOLLO_API_KEY=your_apollo_api_key
HUNTER_API_KEY=your_hunter_api_key
SNOV_CLIENT_ID=your_snov_client_id
SNOV_CLIENT_SECRET=your_snov_client_secret
ZEROBOUNCE_API_KEY=your_zerobounce_api_key
BRAVE_SEARCH_API_KEY=your_brave_api_key

# ── Limits ───────────────────────────────────────────────
DAILY_RESEARCH_LIMIT=5000
QA_SAMPLE_RATE=0.05
WEBSITE_TRUST_THRESHOLD=60
MIN_CONTACT_CONFIDENCE=50

# ── Server ───────────────────────────────────────────────
PORT=4400
NODE_ENV=production
LOG_LEVEL=info
