{
  "name": "aaziko-buyer-intelligence",
  "version": "1.0.0",
  "description": "Buyer Intelligence Layer — transforms trade data into verified buyer profiles",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "etl:extract": "tsx src/services/etl/pipeline.ts",
    "etl:hydrate": "python3 data-pipeline/run_all.py",
    "etl:buyers": "python3 data-pipeline/loaders/build_buyer_profiles.py",
    "etl:products": "python3 data-pipeline/loaders/build_product_index.py",
    "etl:customs": "python3 data-pipeline/loaders/build_customs_index.py",
    "lint": "eslint src/"
  },
  "keywords": [
    "buyer-intelligence",
    "trade-data",
    "enrichment"
  ],
  "author": "Aaziko",
  "license": "UNLICENSED",
  "dependencies": {
    "@qdrant/js-client-rest": "^1.9.0",
    "axios": "^1.7.2",
    "bullmq": "^5.8.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "http-proxy-agent": "^5.0.0",
    "https-proxy-agent": "^5.0.1",
    "ioredis": "^5.4.1",
    "mongodb": "^6.7.0",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1",
    "whois-json": "^1.3.1",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.15.4",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
